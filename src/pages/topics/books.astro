---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import BookReview from '../../components/BookReview.astro';
import { getCollection } from 'astro:content';

// Get all book reviews from content collection
const allBooks = await getCollection('book-reviews');

// Sort by year read (newest first) and then by title
const books = allBooks
  .map(entry => ({
    ...entry.data,
    // Remove 'book-reviews/' prefix from the ID for cleaner URLs
    slug: (entry.id || entry.slug).replace(/^book-reviews\//, '')
  }))
  .sort((a, b) => {
    if (b.yearRead !== a.yearRead) {
      return b.yearRead - a.yearRead;
    }
    return a.title.localeCompare(b.title);
  });

console.log('books:', books);
---

<Layout title="Books | Aarya Patel">
  <div class="max-w-4xl mx-auto px-4 py-12 space-y-6">

    <!-- Page Header -->
    <section class="text-center py-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">📚 Books I've Read</h1>
      <p class="text-xl text-gray-600 dark:text-gray-400">My reading journey and book reviews</p>
      <p class="text-sm text-gray-500">Found {books.length} books</p>
    </section>

    <!-- Book Reviews Grid -->
    <div class="grid gap-4 md:grid-cols-2">
      {books.map(book => (
        <a href={`/topics/books/${book.slug}`} class="block group">
          <Card title={book.title} emoji="📖">
            <p class="text-gray-600 dark:text-gray-400">by {book.author}</p>
            <div class="flex items-center gap-4 mt-2 text-sm text-gray-500">
              <span>Read: {book.yearRead}</span>
              <span class="text-yellow-400">{'★'.repeat(book.rating)}{'☆'.repeat(5 - book.rating)}</span>
            </div>
            <p class="text-blue-400 group-hover:underline mt-2">Click to read review →</p>
          </Card>
        </a>
      ))}
    </div>

    <!-- Template Card -->
    <Card title="Write Your Own Review!" emoji="✍️">
      <p class="mb-4">
        Want to add a book review? Use the template in the <code class="bg-gray-200 dark:bg-slate-700 px-2 py-1 rounded">templates/</code> folder!
      </p>
      <p class="mb-4 text-gray-600 dark:text-gray-400 text-sm">
        Just copy the template, fill in your thoughts, and save it to <code class="bg-gray-200 dark:bg-slate-700 px-2 py-1 rounded">src/content/book-reviews/</code>
      </p>
      <p class="text-sm text-gray-500 dark:text-gray-500">
        <strong>Required fields:</strong> title, author, yearRead, rating, summary, learned, favoritePart, recommend
      </p>
    </Card>

    <!-- Back to Home -->
    <div class="text-center pt-4">
      <a href="/" class="text-blue-400 hover:underline">← Back to Home</a>
    </div>

  </div>
</Layout>
