---
import Layout from '../../../layouts/Layout.astro';
import BookReview from '../../../components/BookReview.astro';
import { getCollection, render } from 'astro:content';

// Generate all possible book routes
export async function getStaticPaths() {
  const books = await getCollection('book-reviews');
  return books.map((entry) => {
    // Remove 'book-reviews/' prefix from entry.id
    const slug = entry.id.replace(/^book-reviews\//, '');
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { data } = entry;
---

<Layout title={`${data.title} | Book Review | Aarya Patel`}>
  <div class="max-w-4xl mx-auto px-4 py-12 space-y-6">

    <!-- Back to Books List -->
    <div class="mb-4">
      <a href="/topics/books" class="text-blue-400 hover:underline">← Back to all books</a>
    </div>

    <!-- Book Review -->
    <BookReview
      title={data.title}
      author={data.author}
      yearRead={data.yearRead}
      rating={data.rating}
      summary={data.summary}
      learned={data.learned}
      favoritePart={data.favoritePart}
      recommend={data.recommend}
    >
      <div class="markdown-content">
        <h3>Full Review</h3>
        <Content />
      </div>
    </BookReview>

  </div>
</Layout>
