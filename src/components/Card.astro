---
/**
 * Card component for displaying content sections
 * @prop {string} title - Card title
 * @prop {string} emoji - Optional emoji icon
 * @prop {string} content - Card content (HTML allowed)
 */

interface Props {
  title: string;
  emoji?: string;
  content?: string;
}

const { title, emoji = '', content = '' } = Astro.props;
---

<div class="bg-white dark:bg-slate-800 rounded-xl p-6 shadow-md hover:shadow-lg transition-shadow">
  {emoji && (
    <h2 class="text-2xl font-bold mb-4 flex items-center gap-2 text-gray-800 dark:text-gray-100">
      <span>{emoji}</span>
      <span>{title}</span>
    </h2>
  )}
  {!emoji && (
    <h2 class="text-2xl font-bold mb-4 text-gray-800 dark:text-gray-100">{title}</h2>
  )}

  <div class="prose dark:prose-invert max-w-none">
    <slot />
  </div>
</div>

<style>
  /* Prose styles for content */
  .prose {
    color: inherit;
    line-height: 1.6;
  }
  .prose h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .prose ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin: 1rem 0;
  }
  .prose li {
    margin-bottom: 0.5rem;
  }
  .prose a {
    color: #60a5fa;
    text-decoration: none;
  }
  .prose a:hover {
    text-decoration: underline;
  }
  .prose strong {
    font-weight: 600;
  }
  .prose p {
    margin-bottom: 1rem;
  }
</style>
